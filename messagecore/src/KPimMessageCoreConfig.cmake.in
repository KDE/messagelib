@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
if(@KF6Mime_FOUND@)
    find_dependency(
        KF6Mime
        "@KF_MIN_VERSION@"
    )
else()
    find_dependency(
        KPim6Mime
        "@KMIME_LIB_VERSION@"
    )
    if(NOT TARGET KF6::Mime)
        add_library(KF6::Mime ALIAS KPim6::Mime)
    endif()
endif()
find_dependency(
    KPim6MimeTreeParser
    "@MIMETREEPARSER_LIB_VERSION@"
)

find_dependency(
    Qt6Gui
    "@QT_REQUIRED_VERSION@"
)

find_dependency(
    KF6ColorScheme
    "@KF_MIN_VERSION@"
)

find_dependency(
    KF6Config
    "@KF_MIN_VERSION@"
)

find_dependency(
    KPim6IdentityManagementCore
    "@IDENTITYMANAGEMENT_LIB_VERSION@"
)

find_dependency(
    KF6CoreAddons
    "@KF_MIN_VERSION@"
)

find_dependency(
    Qt6Widgets
    "@QT_REQUIRED_VERSION@"
)

include("${CMAKE_CURRENT_LIST_DIR}/KPim6MessageCoreTargets.cmake")
