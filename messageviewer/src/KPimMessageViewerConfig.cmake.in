@PACKAGE_INIT@
include(CMakeFindDependencyMacro)
find_dependency(
    KPim6PimCommon
    "@PIMCOMMON_LIB_VERSION@"
)
find_dependency(
    KPim6MessageCore
    "@MESSAGELIB_LIB_VERSION@"
)
find_dependency(
    KPim6MimeTreeParser
    "@MIMETREEPARSER_LIB_VERSION@"
)
find_dependency(
    KPim6WebEngineViewer
    "@MESSAGELIB_LIB_VERSION@"
)
find_dependency(
    KPim6Akonadi
    "@AKONADI_VERSION@"
)
if(@KF6Mime_FOUND@)
    find_dependency(
        KF6Mime
        "@KF_MIN_VERSION@"
    )
else()
    find_dependency(
        KPim6Mime
        "@KMIME_LIB_VERSION@"
    )
    if(NOT TARGET KF6::Mime)
        add_library(KF6::Mime ALIAS KPim6::Mime)
    endif()
endif()
find_dependency(
    KF6Contacts
    "@KF_MIN_VERSION@"
)
find_dependency(
    KPim6Libkleo
    "@LIBKLEO_LIB_VERSION@"
)
find_dependency(
    KF6Service
    "@KF_MIN_VERSION@"
)
find_dependency(
    KPim6AkonadiMime
    "@AKONADIMIME_LIB_VERSION@"
)

include("${CMAKE_CURRENT_LIST_DIR}/KPim6MessageViewerTargets.cmake")
