@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(
    KPim6MimeTreeParser
    "@MIMETREEPARSER_LIB_VERSION@"
)
find_dependency(
    KPim6MessageCore
    "@MESSAGELIB_LIB_VERSION@"
)

find_dependency(
    Qt6Widgets
    "@QT_REQUIRED_VERSION@"
)

find_dependency(
    KF6Mime
    "@KF_MIN_VERSION@"
)
find_dependency(
    KF6I18n
    "@KF_MIN_VERSION@"
)

find_dependency(
    KF6TextCustomEditor
    "@KTEXTADDONS_MIN_VERSION@"
)

include("${CMAKE_CURRENT_LIST_DIR}/KPim6TemplateParserTargets.cmake")
@PACKAGE_INCLUDE_QCHTARGETS@
